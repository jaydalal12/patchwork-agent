# Copy to .env and fill in. Patchwork reads these at startup (see patchwork/config.py).

# --- LLM provider ---------------------------------------------------------
# Which provider drives the agent. One of: anthropic | gemini
# If unset, Patchwork auto-selects whichever key is present (Anthropic preferred).
PATCHWORK_LLM_PROVIDER=

# Anthropic (primary)
ANTHROPIC_API_KEY=
PATCHWORK_ANTHROPIC_MODEL=claude-opus-4-8

# Google Gemini (fallback — used if no Anthropic key)
GEMINI_API_KEY=
PATCHWORK_GEMINI_MODEL=gemini-2.5-pro
# Client-side requests/min cap (match your tier): free 2.5-flash ~10,
# free 2.0-flash-lite ~30, paid much higher. Long 20+ call runs need >=25.
PATCHWORK_GEMINI_RPM=10

# --- GitHub ---------------------------------------------------------------
# Fine-grained or classic PAT with repo + pull-request scope.
GITHUB_TOKEN=

# --- Agent limits ---------------------------------------------------------
PATCHWORK_MAX_TOOL_CALLS=60
PATCHWORK_CONTEXT_TOKEN_BUDGET=120000
PATCHWORK_LOG_LEVEL=INFO
# Emit one JSON object per log line (production) vs. pretty text (local dev).
PATCHWORK_LOG_JSON=false
